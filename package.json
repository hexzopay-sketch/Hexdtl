{
  "name": "hexdtl-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "HexDTL \u2014 Chrome DevTools for the terminal",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "node packages/cli/bin/hexdtl.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.base.json"
  },
  "devDependencies": {
    "@rolldown/binding-linux-x64-gnu": "^1.1.4",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.17",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18"
  }
}
